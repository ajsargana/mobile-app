{
  "expo": {
    "name": "AURA50",
    "slug": "aura50",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "aura50",
    "description": "AURA50 - Revolutionary Mobile-First Blockchain with Temporal Trust",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#141E28"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aura50.mobile",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.aura50.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#141E28"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5DADE2",
          "sounds": ["./assets/sounds/coin_received.wav"],
          "androidMode": "default",
          "androidCollapsedTitle": "AURA50"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "aura50-mobile"
      }
    }
  }
}