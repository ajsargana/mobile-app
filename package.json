    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace AURA5O.xcworkspace -scheme AURA5O -configuration Release -destination generic/platform=iOS -archivePath AURA5O.xcarchive archive",
    "dev:android": "react-native run-android --variant=debug",
    "dev:ios": "react-native run-ios --simulator='iPhone 15'",
    "install:pods": "cd ios && pod install"
  },
